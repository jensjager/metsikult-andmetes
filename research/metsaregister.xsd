<?xml version="1.0" encoding="UTF-8"?>
<xs:schema
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xmlns:gml="http://www.opengis.net/gml"
	xmlns:mets="http://metsaregister.x-road.eu"
	elementFormDefault="qualified"
	targetNamespace="http://metsaregister.x-road.eu">
	<xs:import namespace="http://www.opengis.net/gml" schemaLocation="http://schemas.opengis.net/gml/3.1.1/base/gml.xsd" />
	<xs:import namespace="http://www.w3.org/2005/05/xmlmime" schemaLocation="http://www.w3.org/2005/05/xmlmime"/>

	<xs:element name="eraldisEsitamine" type="mets:eraldisEsitamineParing" />
	<xs:element name="eraldisEsitamineRequest" type="mets:eraldisEsitamineParing" />
	<xs:element name="eraldisEsitamineResponse" type="mets:eraldisEsitamineVastus" />

	<xs:element name="eraldisStaatusRequest" type="mets:eraldisStaatusParing" />
	<xs:element name="eraldisStaatusResponse" type="mets:eraldisStaatusVastus" />

	<xs:element name="eraldisKustutamineRequest" type="mets:eraldisKustutamineParing" />
	<xs:element name="eraldisKustutamineResponse" type="mets:eraldisKustutamineVastus" />

	<xs:element name="teatisEsitamine" type="mets:teatisEsitamineParing" />
	<xs:element name="teatisEsitamineRequest" type="mets:teatisEsitamineParing" />
	<xs:element name="teatisEsitamineResponse" type="mets:teatisEsitamineVastus" />

	<xs:element name="teatisOlek" type="mets:teatisOlekParing" />
	<xs:element name="teatisOlekRequest" type="mets:teatisOlekParing" />
	<xs:element name="teatisOlekResponse" type="mets:teatisOlekVastus" />

	<xs:element name="yksusEraldisedRequest" type="mets:yksusEraldisedParing" />
	<xs:element name="yksusEraldisedResponse" type="mets:yksusEraldisedVastus" />

	<xs:element name="teatisAllalaadimine" type="mets:teatisAllalaadimineVastus" />

	<xs:element name="findUsage" type="mets:findUsageParing" />
	<xs:element name="findUsageRequest" type="mets:findUsageParing"/>
	<xs:element name="findUsageResponse" type="mets:findUsageVastus"/>

	<xs:element name="mkeAndmed" type="mets:mkeAndmedParing" />
	<xs:element name="mkeAndmedRequest" type="mets:mkeAndmedParing" />
	<xs:element name="mkeAndmedResponse" type="mets:mkeAndmedVastus" />

	<!-- Eraldis esitamine -->
	<xs:complexType name="eraldisEsitamineParing">
		<xs:annotation>
			<xs:documentation>Esitatavad inventeerimisandmed</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ettevote" type="mets:registrikoodType">
				<xs:annotation>
					<xs:documentation>Metsakorraldusettevõte registrikood</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="epost" type="mets:epostType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>E-post millele saadetakse teavitusi esitatud eraldiste kohta.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="yksused">
				<xs:annotation>
					<xs:documentation>Eraldiste andmed kinnistute või RMK metskondade kaupa. Kohustuslik esitada vähemalt ühe üksuse eraldis(t)e andmed.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="yksus" type="mets:yksusEsitamine" maxOccurs="unbounded" />
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="yksusEsitamine">
		<xs:complexContent>
			<xs:extension base="mets:yksusAndmedAbstact">
				<xs:sequence>
					<xs:element name="dokument" type="mets:manus" minOccurs="0" />
					<xs:element name="eraldised">
						<xs:annotation>
							<xs:documentation>Eraldiste inventeerimise andmed</xs:documentation>
						</xs:annotation>
						<xs:complexType>
							<xs:sequence>
								<xs:element name="eraldis" type="mets:eraldisEsitamine" maxOccurs="unbounded" />
							</xs:sequence>
						</xs:complexType>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>

	<xs:complexType name="yksusAndmedAbstact" abstract="true">
		<xs:sequence>
			<xs:element name="kinnistuNimi" type="mets:nimetusType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Kinnistu nimi.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:choice>
				<xs:element name="kinnistuNr" type="mets:kinnistuNrType" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Kinnistu number. Erametsa korral on vaja täita. Kohustuslik, kui metskond ei ole täidetud.</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="metskond" type="mets:nimetusType" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Metskond. RMK täidab metskonna välja. Kohustuslik, kui kinnistu nr ei ole täidetud.</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="eraldisEsitamine">
		<xs:complexContent>
			<xs:extension base="mets:eraldisAndmedAbstract">
				<xs:sequence>
					<xs:element name="inventKuup" type="xs:date">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Inventeerimise kuupäev</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="vKood" type="mets:ehakKoodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Valla või linna kood. EHAK kood</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="mKood" type="mets:ehakKoodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Maakonna kood. EHAK kood</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="takseerija" type="mets:isikukoodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Metsakorraldaja/takseerija isikukood</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="pindala" type="mets:eraldisePindalaType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Eraldise pindala</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kuivendatud" type="mets:tunnusType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Kuivenduse tunnus. Lubatud väärtused 1 ja 0 (1 - kuivendatud). MK juhendi lisa 6</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kasvukoht" type="mets:koodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Kasvukohatüüp. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="peapuuliik" type="mets:koodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 14</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="korgusIndeks" type="mets:korgusType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Kõrgusindeks. MK juhendi lisa 10</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="boniteet" type="mets:koodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Boniteediklass. Väärtus peab leiduma klassifikaatoris. MK juhendi lisad 2 ja 10. Edastatakse kood kujul 0,1,2 jne</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="tuleohuklass" type="mets:koodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Tuleohuklass. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 4</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="arenguklass" type="mets:koodType">
						<xs:annotation>
							<xs:documentation>Kohustuslik. Arenguklass. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 3</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kkVanus" type="mets:vanusType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Kaalutud keskmine vanus. Metsa majandamise eeskiri §3</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="kkRaievanus" type="mets:vanusType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Kaalutud keskmine raievanus. Metsa majandamise eeskiri §3</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="juurdekasv" type="mets:juurdekasvType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Tagavara juurdekasv. MK juhendi lisa 12</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="rPindala1" type="mets:rpindalaType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Esimese rinde rinnaspindala.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="taius1" type="mets:taiusType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Esimese rinde täius. MK juhendi lisa 11 punkt 2</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="rPindala2" type="mets:rpindalaType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Teise rinde rinnaspindala</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="taius2" type="mets:taiusType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Teise rinde täius. MK juhendi lisa 11 punkt 2</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="tagavara1Ha" type="mets:tagavaraType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Esimese rinde hektaritagavara. MK juhendi lisa 11 punkt 1</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="tagavara2Ha" type="mets:tagavaraType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Teise rinde hektaritagavara. MK juhendi lisa 11 punkt 1</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="tagavaraYHa" type="mets:tagavaraType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Üksikpuude rinde hektaritagavara. MK juhendi lisa 11 punkt 1</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="puudeArv" type="mets:puudeArvType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Puude arv. Täidetakse arenguklassi S ja N korral hektari kohta</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="jPuudeArv" type="mets:puudeArvType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Järelkasvu puude arv</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="yPuudeArv" type="mets:puudeArvType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Üksikpuude arv</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="tagavaraS" type="mets:tagavaraType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Surnud puude hektaritagavara</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="tagavaraL" type="mets:tagavaraType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Lamapuidu hektaritagavara</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="prLiitus" type="mets:protsentType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Põõsarinde liitus</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="geomeetria" type="gml:MultiPolygonType">
						<xs:annotation>
							<xs:documentation>Eralduse ruumikuju koordinaadid GML formaadis</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="elemendid" minOccurs="0">
						<xs:complexType>
							<xs:sequence>
								<xs:element name="element" type="mets:eraldisElement" maxOccurs="unbounded" />
							</xs:sequence>
						</xs:complexType>
					</xs:element>
					<xs:element name="isearasused" minOccurs="0">
						<xs:complexType>
							<xs:sequence>
								<xs:element name="isearasus" type="mets:koodType" maxOccurs="unbounded">
									<xs:annotation>
										<xs:documentation>Iseärasuse kood. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 9</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:complexType>
					</xs:element>
					<xs:element name="kahjustused" minOccurs="0">
						<xs:complexType>
							<xs:sequence>
								<xs:element name="kahjustus" type="mets:eraldisKahjustus" maxOccurs="unbounded" />
							</xs:sequence>
						</xs:complexType>
					</xs:element>
					<xs:element name="tood" minOccurs="0">
						<xs:complexType>
							<xs:sequence>
								<xs:element name="too" type="mets:eraldisToo" maxOccurs="unbounded" />
							</xs:sequence>
						</xs:complexType>
					</xs:element>
					<xs:element name="tekst" type="xs:string" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Reserveeritud tuleviku vajaduste jaoks</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>

	<xs:complexType name="eraldisAndmedAbstract" abstract="true">
		<xs:sequence>
			<xs:element name="katastriNr" type="mets:katastriNrType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Katastritunnus kujul xxxxx:xxx:xxxx. Kohustuslik, kui esitaja ei ole RMK. RMK puhul soovituslik.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="kvartaliNr" type="mets:kvartaliNrType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Kvartali number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="eraldiseNr" type="mets:erldiseNrType" minOccurs="1">
				<xs:annotation>
					<xs:documentation>Kohustuslik. Eraldise number</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="eraldisElement">
		<xs:sequence>
			<xs:element name="rinne" type="mets:koodType">
				<xs:annotation>
					<xs:documentation>Kohustuslik. Väärtus peab leiduma klassifikaatoris</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="puuliik" type="mets:koodType">
				<xs:annotation>
					<xs:documentation>Kohustuslik. Väärtus peab leiduma klassifikaatoris</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="paritolu" type="mets:koodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Väärtus peab leiduma klassifikaatoris
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="osakaal" type="mets:protsentType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Osakaal</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="vanus" type="mets:vanusType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Vanus</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="synniaasta" type="xs:gYear" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Sünniaasta</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="korgus" type="mets:korgusType">
				<xs:annotation>
					<xs:documentation>Kohustuslik. Kõrgus meetrites</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="diameeter" type="mets:diameeterType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Sentimeetrites</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="rinnaspindala" type="mets:rpindalaType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Rinnaspindala</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="tagavara" type="mets:tagavaraType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tagavara</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="arv" type="mets:puudeArvType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Puude arv</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="enamus" type="mets:tunnusType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Peapuuliigi tunnus. Lubatud väärtused 1 või 0</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="eraldisToo">
		<xs:sequence>
			<xs:element name="too" type="mets:koodType">
				<xs:annotation>
					<xs:documentation>Kohustuslik. Töö liik.Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 17</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="jarjekord" type="mets:tunnusType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Järjekord. Võimalikud väärtused 0, 1, 2, 3, 8, 9</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="rRinne" type="mets:koodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Raiutava puuliigi rinne. Võib olla täidetud, kui kavandatud töö on raie.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="rPuuliik" type="mets:koodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Raiutav puuliik. Peab ühtima puuliigiga tabelis element. Võib olla täidetud, kui kavandatud töö on raie.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="rVanus" type="mets:vanusType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Raiutava puuliigi vanus. Võib olla täidetud, kui kavandatud töö on raie.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="rprotsent" type="mets:protsentType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Väljaraie protsent. Väärtus 0..100. Võib olla täidetud, kui kavandatud töö on raie.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="uPuuliik" type="mets:koodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Uuendatav puuliik. Väärtus peab leiduma klassifikaatoris.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="tooAasta" type="xs:gYear" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Töö aasta</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="eraldisKahjustus">
		<xs:sequence>
			<xs:element name="kPuuliik" type="mets:koodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Kahjustatud puuliik. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 9</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="kVanus" type="mets:vanusType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Kahjustatud puuliigi vanus. Vanus peab ühtima puuliigi vanusega tabelis element.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="kPohjus" type="mets:koodType" minOccurs="1">
				<xs:annotation>
					<xs:documentation>Kahjustuse põhjus. Väärtus peab leiduma klassifikaatoris. MK juhendi lisa 16</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="kOsakaal" type="mets:protsentType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Kahjustuse osakaal</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="kRinne" type="mets:koodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Rinne. Väärtus peab leiduma klassifikaatoris</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<!-- Eraldis vastus -->
	<xs:complexType name="eraldisEsitamineVastus">
		<xs:sequence>
			<xs:element name="yldineStaatus" type="mets:staatusEnum">
				<xs:annotation>
					<xs:documentation>Üldine staatus. Võimalikud väärtused OK/NOK</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="eraldised">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="eraldis" type="mets:eraldisVastus" maxOccurs="unbounded" />
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="eraldisVastus">
		<xs:complexContent>
			<xs:extension base="mets:eraldisAndmedAbstract">
				<xs:sequence>
